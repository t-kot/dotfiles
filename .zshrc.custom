export LT_PRODUCTION_APP_SERVER_KEY='~/.ssh/id_rsa'
export LT_PRODUCTION_BASTION_SERVER_KEY='~/.ssh/id_rsa'
export GOROOT_BOOTSTRAP=$GOROOT

export PYENV_ROOT="$HOME/.pyenv"
